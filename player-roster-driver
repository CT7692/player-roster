#include "Rydel_Player.h"
#include<iostream>
#include<iomanip>
#include<string>
#include<cstring>
#include<cstdlib>

using namespace std;



void getInput(Player*);
void displayAllPlayerRecord(Player*);
const string LINE(60, '*');
string getName();
int getID();
int getAge();
double getBatAverage();

const int SIZE = 5;

int main()
{
	Player* ptrPlayer = nullptr;
	ptrPlayer = new Player[SIZE];
	
	getInput(ptrPlayer);
	displayAllPlayerRecord(ptrPlayer);

	delete[] ptrPlayer;
	return 0;
}



void getInput(Player* ptr)
{
	string pName;
	int pNum;
	int pAge;
	double batAvg;

	for (int i = 0; i < SIZE; i++)
	{
		cout << "\nEnter player " << i + 1 << " information" << endl;
		pNum = getID();
		pName = getName();
		pAge = getAge();
		batAvg = getBatAverage();

		ptr[i].setPlayerName(pName);
		ptr[i].setPlayerNumber(pNum);
		ptr[i].setPlayerAge(pAge);
		ptr[i].setBatAverage(batAvg);

	}
}

void displayAllPlayerRecord(Player* ptr)
{
	for (int i = 0; i < SIZE; i++)
	{
		cout << LINE << endl;
		cout << ptr[i].getPlayerNumber() << "\t" << left << setw(20) << ptr[i].getPlayerName()
			<< "\t" << ptr[i].getPlayerAge() << "\t" << setprecision(3)
			<< fixed << ptr[i].getBatAverage() << endl;
	}	
}

string getName()
{
	string name;
	cout << "Enter player name: ";
	cin.ignore();
	getline(cin, name);
	return name;
}

int getID()
{
	int num;
	cout << "\nEnter player number: ";
	cin >> num;
	if (num < 0 || 99 < num)
	{
		while (num < 0 || 99 < num)
		{
			cout << "Number must be 0 ~ 99" << endl;
			cout << "Re-enter number: ";
			cin >> num;
		}
	}
	return num;
}

int getAge()
{
	int age;
	cout << "Enter player age: ";
	cin >> age;
	if (age < 4 || age > 16)
	{
		while (age < 4 || age > 16)
		{
			cout << "Age must be 4 ~ 16" << endl;
			cout << "Re-enter age: ";
			cin >> age;
		}
	}
	return age;
}

double getBatAverage()
{
	double batAvg;
	cout << "Enter batting average: ";
	cin >> batAvg;
	if (batAvg < 0 || 1 < batAvg)
	{
		while (batAvg < 0 || 1 < batAvg)
		{
			cout << "Batting average must be 0 ~ 1" << endl;
			cout << "Re-enter batting average: ";
			cin >> batAvg;
		}
	}
	return batAvg;
}


